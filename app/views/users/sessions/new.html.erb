<div class="loginbox">
  <div class="field">
    <h2>ログイン</h2>
  </div>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
    
      <div class="field">
      <%= f.email_field :email,
          placeholder: "ログインID（メールアドレス）", class: "入力" %>
      </div>

      <div class="field">
        <%= f.password_field :password,
          placeholder: "パスワード", class: "入力" %>
      </div>    

      <% if devise_mapping.rememberable? %>
        <div class="field">
          <%= f.check_box :remember_me, class: "checkbox" %>
          <%= f.label :remember_me do %>
             ログイン<span class="latin">ID</span>を保存する
          <% end %>
        </div>
      <% end %>

      <div class="actions">
        <%= f.submit "ログイン", class: "login-btn" %>
      </div>
  <% end %>


<%= render "users/shared/links" %>
</div>
